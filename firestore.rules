// ============================================================
//  Firestore Security Rules for Devverse Intern Tracker
//  Paste this in: Firebase Console → Firestore → Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sessions/{sessionId} {
      // Interns can create their own sessions
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      // Interns can update/read their own sessions
      allow read, update: if request.auth != null
        && (resource.data.uid == request.auth.uid
            || request.auth.token.email == "vjysupermacy@gmail.com");

      // Admin can read all sessions
      allow read: if request.auth != null
        && request.auth.token.email == "vjysupermacy@gmail.com";
    }
  }
}
